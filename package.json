{
	"name": "triple-b-prints",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"smoke:checkout-boundary": "node scripts/smoke-checkout-boundary.mjs",
		"smoke:public-copy-boundary": "node scripts/smoke-public-copy-boundary.mjs",
		"smoke:request-handoff": "node --experimental-strip-types scripts/smoke-request-handoff.mjs",
		"smoke:print-job-handoff": "node --experimental-strip-types scripts/smoke-print-job-handoff.mjs",
		"smoke:artwork-upload": "node scripts/smoke-artwork-upload.mjs",
		"smoke:bbb": "npm run smoke:checkout-boundary && npm run smoke:public-copy-boundary && npm run smoke:request-handoff && npm run smoke:print-job-handoff && npm run smoke:artwork-upload"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@stripe/stripe-js": "^9.4.0",
		"@vercel/blob": "^2.4.1",
		"sharp": "^0.34.5"
	}
}
